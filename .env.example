# Supabase project credentials — get these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — used ONLY by server-side code (cron, scripts). Never ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Random string used by Vercel Cron to authenticate scheduled invocations.
# Generate: `openssl rand -hex 32`
CRON_SECRET=

# Active pool year (e.g. 2026). Used by the scraper + scoring engine.
TDF_YEAR=2026
